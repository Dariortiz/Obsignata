{
  "name": "Obsignata Development Environment",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "workspace",
  "workspaceFolder": "/workspace",

  // Mount the host ~/.claude directory so Claude Code stays authenticated
  // across container rebuilds — no re-login needed.
  "mounts": [
    {
      "source": "${localEnv:USERPROFILE}/.claude",
      "target": "/home/node/.claude",
      "type": "bind"
    }
  ],

  // Forward the three app ports and label them for the VS Code Ports panel
  "forwardPorts": [3000, 3001, 8545],
  "portsAttributes": {
    "3000": { "label": "Frontend (Vite)" },
    "3001": { "label": "Backend (Express API)" },
    "8545": { "label": "Hardhat Local Blockchain Node" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        // TypeScript / JavaScript
        "ms-vscode.vscode-typescript-next",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",

        // Solidity / Hardhat smart contracts
        "NomicFoundation.hardhat-solidity",

        // Claude AI coding assistant
        "Anthropic.claude-code",

        // Markdown authoring and PDF export
        "yzhang.markdown-all-in-one",
        "yzane.markdown-pdf",
        "tom-latham.markdown-pdf-plus",
        "DavidAnson.vscode-markdownlint",

        // UI theme
        "manuthebyte.dynamic-icon-theme"
      ],
      "settings": {
        // Point VS Code at the workspace TypeScript installation
        "js/ts.tsdk.path": "/workspace/backend/node_modules/typescript/lib",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },
  // Set SHELL so Claude Code can locate a POSIX shell for Bash tool calls.
  // This mirrors the ENV in the Dockerfile; both are needed because VS Code
  // injects remoteEnv after the container starts, while ENV covers non-VS Code
  // processes (e.g. direct docker exec sessions).
  "remoteEnv": {
    "SHELL": "/bin/bash"
  },

  "remoteUser": "node"
}
