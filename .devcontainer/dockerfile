FROM node:20-alpine

# Tools needed for builds, git operations, and native addons
# bash is required so Claude Code (claude-code extension) can execute shell commands
RUN apk add --no-cache curl git python3 py3-pip bash

# Tell every process in the container where to find the shell.
# Claude Code reads SHELL to locate a POSIX-compatible interpreter.
ENV SHELL=/bin/bash

WORKDIR /workspace

# Pre-install dependencies so named volumes are populated on first container start.
# docker-compose mounts these as named volumes, preserving them across rebuilds.
COPY hardhat/package.json ./hardhat/
COPY backend/package.json ./backend/
COPY frontend/package.json ./frontend/

RUN cd /workspace/hardhat && npm install && \
    cd /workspace/backend && npm install && \
    cd /workspace/frontend && npm install

# Keep container alive — VS Code attaches to it via devcontainer
CMD ["sleep", "infinity"]